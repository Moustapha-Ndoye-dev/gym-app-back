PORT=5000
DATABASE_URL="file:./prisma/gym_database.sqlite"
JWT_SECRET="replace_with_a_long_random_secret"
NODE_ENV=development

# Default accounts are created only if these are set to strong, non-placeholder values
DEFAULT_ADMIN_PASSWORD="replace_with_a_strong_admin_password"
DEFAULT_SUPERADMIN_PASSWORD="replace_with_a_strong_superadmin_password"

# Limite de débit : uniquement sur POST /api/auth/login (tentatives échouées).
# En dev, le plancher élevé évite de bloquer les tests locaux.
LOGIN_RATE_LIMIT_MAX=10
