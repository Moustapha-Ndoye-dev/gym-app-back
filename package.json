  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "nodemon --exec ts-node src/server.ts",
    "test": "powershell -File tests/test-all.ps1",
    "db:push": "prisma db push --accept-data-loss",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
